<style>
.card {
  width: 200px;
  height: 200px;
  perspective: 1000px;
}

.inner {
  transition: transform 0.6s;
  transform-style: preserve-3d;
}

.card:hover .inner {
  transform: rotateY(180deg);
}
</style>

<div class="card">
  <div class="inner">
    Flip Me
  </div>
</div>
<style>
a {
  text-decoration: none;
  position: relative;
}

a::after {
  content: "";
  width: 0;
  height: 2px;
  background: black;
  position: absolute;
  left: 0;
  bottom: -5px;
  transition: 0.3s;
}

a:hover::after {
  width: 100%;
}
</style>

<a href="#">Hover Link</a>
<style>
