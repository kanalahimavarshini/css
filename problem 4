<style>
button {
  padding: 10px 20px;
  background: black;
  color: white;
  border: none;
  transition: 0.3s;
}

button:hover {
  box-shadow: 0 0 10px cyan, 0 0 20px cyan;
}
</style>

<button>Glow</button>
<style>
.text {
  position: relative;
  left: -200px;
  animation: slide 2s forwards;
}

@keyframes slide {
  to { left: 0; }
}
</style>

<div class="text">Slide In</div>
<style>
button {
  padding: 10px 20px;
  background: blue;
  color: white;
  border: none;
  box-shadow: 0 5px #333;
}

button:active {
  transform: translateY(5px);
  box-shadow: 0 0 #333;
}
</style>

<button>Press</button>