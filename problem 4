<style>
button {
  padding: 10px 20px;
  background: black;
  color: white;
  border: none;
  transition: 0.3s;
}

button:hover {
  box-shadow: 0 0 10px cyan, 0 0 20px cyan;
}
</style>

<button>Glow</button>
<style>
.text {
  position: relative;
  left: -200px;
  animation: slide 2s forwards;
}

@keyframes slide {
  to { left: 0; }
}
</style>

<div class="text">Slide In</div>
<style>
button {
  padding: 10px 20px;
  background: blue;
  color: white;
  border: none;
  box-shadow: 0 5px #333;
}

button:active {
  transform: translateY(5px);
  box-shadow: 0 0 #333;
}
</style>

<button>Press</button>
<style>
.card {
  position: relative;
  width: 200px;
}

.card img {
  width: 100%;
}

.info {
  position: absolute;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  color: white;
  width: 100%;
  opacity: 0;
  transition: 0.3s;
}

.card:hover .info {
  opacity: 1;
}
</style>

<div class="card">
  <img src="https://via.placeholder.com/200">
  <div class="info">Details</div>
</div>
<style>
.divider {
  height: 20px;
  background: repeating-linear-gradient(
    45deg,
    black,
    black 10px,
    white 10px,
    white 20px
  );
}
</style>

<div class="divider"></div>
<style>
.card {
  height: 100px;
  background: lightblue;
  transition: 0.3s;
}

.card:hover {
  height: 200px;
}
</style>

<div class="card"></div>
<style>
.box {
  width: 100px;
  height: 100px;
  border: 5px solid red;
  animation: spin 2s infinite linear;
}

@keyframes spin {
  100% { transform: rotate(360deg); }
}
</style>

<div class="box"></div>
<style>
.progress {
  position: fixed;
  top: 0;
  height: 5px;
  background: red;
  width: 50%;
}
</style>

<div class="progress"></div>
<style>
span {
  display: inline-block;
  animation: wave 1s infinite;
}

@keyframes wave {
  50% { transform: translateY(-10px); }
}
</style>

<span>W</span><span>A</span><span>V</span><span>E</span>
<style>
.tooltip {
  position: relative;
}

.tooltip::after {
  content: "";
  position: absolute;
  border: 5px solid transparent;
  border-top-color: black;
  top: 100%;
  left: 10px;
}
</style>

<div class="tooltip">Tooltip</div>
<style>
img:active {
  transform: scale(0.9);
}
</style>

<img src="https://via.placeholder.com/150">
<style>
.box {
  padding: 20px;
  border: 5px solid;
  border-image: linear-gradient(red, blue) 1;
}
</style>

<div class="box">Gradient Border</div>
<style>
.blink {
  animation: blink 1s infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}
</style>

<p class="blink">Blinking Text</p>
<style>
body {
  height: 100vh;
  background: linear-gradient(45deg, red, yellow);
}
</style>
<style>
.ripple {
  width: 50px;
  height: 50px;
  background: blue;
  border-radius: 50%;
  animation: ripple 1.5s infinite;
}

@keyframes ripple {
  to {
    transform: scale(2);
    opacity: 0;
  }
}
</style>

<div class="ripple"></div>
