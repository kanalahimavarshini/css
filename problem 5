<style>
.card {
  padding: 20px;
  background: linear-gradient(white, lightgray);
  transition: 0.3s;
}

.card:hover {
  background: linear-gradient(blue, purple);
  color: white;
}
</style>

<div class="card">Hover Card</div>
<style>
.icon {
  font-size: 30px;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  50% { transform: scale(1.2); }
}
</style>

<div class="icon">❤️</div>
<style>
.box {
  border: 2px solid black;
  padding: 20px;
  transition: 0.3s;
}

.box:hover {
  padding: 30px;
}
</style>

<div class="box">Expand</div>
<style>
.container {
  position: relative;
}

.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: black;
  opacity: 0;
  transition: 0.3s;
}

.container:hover .overlay {
  opacity: 0.4;
}
</style>

<div class="container">
  <img src="https://via.placeholder.com/200">
  <div class="overlay"></div>
</div>
<style>
p {
  display: inline-block;
  transition: 0.3s;
}

p:hover {
  transform: rotate(10deg);
}
</style>

<p>Rotate Me</p>
<style>
.bar {
  width: 0;
  height: 10px;
  background: green;
  animation: load 2s infinite;
}

@keyframes load {
  to { width: 100%; }
}
</style>

<div class="bar"></div>
<style>
.box {
  width: 100px;
  height: 100px;
  border: 2px solid transparent;
  animation: glow 2s infinite;
}

@keyframes glow {
  50% { border-color: red; }
}
</style>

<div class="box"></div>
<style>
.container {
  height: 50px;
  overflow: hidden;
}

.text {
  transition: 0.3s;
}

.container:hover .text {
  transform: translateY(-50px);
}
</style>

<div class="container">
  <div class="text">Slide Up</div>
</div>