<style>
input {
  width: 120px;
  padding: 8px;
  transition: 0.3s;
}

input:focus {
  width: 220px;
}
</style>

<input type="text" placeholder="Search">
<style>
.box {
  position: relative;
  padding: 20px;
}

.box::before {
  content: "";
  position: absolute;
  height: 3px;
  width: 0;
  background: black;
  top: 0;
  left: 0;
  transition: 0.3s;
}

.box:hover::before {
  width: 100%;
}
</style>

<div class="box">Top Border</div>
<style>
.circle {
  width: 20px;
  height: 20px;
  background: black;
  border-radius: 50%;
  animation: bounce 0.8s infinite alternate;
}

@keyframes bounce {
  to { transform: translateY(-20px); }
}
</style>

<div class="circle"></div>
<style>
h2 {
  display: inline-block;
  animation: flip 2s infinite;
}

@keyframes flip {
  50% { transform: rotateY(180deg); }
}
</style>

<h2>Flip</h2>
<style>
.card {
  width: 150px;
  height: 100px;
  background: white;
  transition: 0.3s;
}

.card:hover {
  box-shadow: 0 0 20px purple;
}
</style>

<div class="card"></div>