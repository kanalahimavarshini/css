<link rel="stylesheet" href="style.css">
/* Element selector */
p {
  color: green;
}

/* Class selector */
.box {
  background-color: yellow;
}

/* ID selector */
#title {
  font-size: 30px;
}

/* Group selector */
h1, h2, p {
  font-family: Arial;
}
div {
  width: 200px;
  padding: 20px;
  border: 5px solid black;
  margin: 10px;
}
body {
  background-color: lightblue;
}

h1 {
  color: #ff5733;
}

div {
  background-image: url("image.jpg");
  background-size: cover;
}
p {
  font-size: 18px;
  font-family: Arial, sans-serif;
  font-weight: bold;
  text-align: center;
  text-transform: uppercase;
}
/* Display types */
div {
  display: block;
}

span {
  display: inline;
}

.box {
  display: inline-block;
}

/* Position */
.box {
  position: relative;
  top: 20px;
  left: 30px;
}
.container {
  display: flex;
  justify-content: center;   /* horizontal */
  align-items: center;       /* vertical */
  height: 100vh;
}

.box {
  width: 100px;
  height: 100px;
  margin: 10px;
  background: orange;
}
.container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.box {
  background: lightgreen;
  padding: 20px;
}
button {
  background: blue;
  color: white;
  transition: 0.3s;
}

button:hover {
  background: red;
}

/* Animation */
@keyframes move {
  from { left: 0; }
  to { left: 200px; }
}

.box {
  position: relative;
  animation: move 2s infinite alternate;
}
body {
  background: white;
}

@media (max-width: 600px) {
  body {
    background: lightgray;
  }
}
a:hover {
  color: red;
}

p::first-letter {
  font-size: 30px;
}

input:focus {
  border: 2px solid blue;
}
:root {
  --main-color: blue;
}

h1 {
  color: var(--main-color);
}
box {
  box-shadow: 2px 2px 10px gray;
}
div {
  background: linear-gradient(to right, red, yellow);
}
